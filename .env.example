# =============================================================================
# Example env file for docker-compose.yml — copy to `.env` before running
# `docker compose up`. Compose auto-loads `.env` from the project root.
#
#   cp .env.example .env
#
# `.env` itself is git-ignored (see .gitignore). Never commit real secrets.
# These defaults are workshop-safe (local-only, plaintext "postgres123") and
# match the fallbacks baked into bin/migrate.sh + infra/locals.tf, so you can
# run the workshop without editing this file at all.
# =============================================================================

# ---- Postgres (workshop-postgres container) ---------------------------------
# Used by docker-compose.yml to bootstrap the database on first start, and by
# bin/migrate.sh when connecting from the host.
POSTGRES_USER=postgres
POSTGRES_PASS=postgres123
POSTGRES_NAME=postgres

# ---- LocalStack (workshop-localstack container) -----------------------------
# LocalStack Community is the default. Set to localstack/localstack-pro and
# provide LOCALSTACK_AUTH_TOKEN if you have a Pro licence (not required for the
# workshop). Leave empty to use the image pinned in docker-compose.yml.
LOCALSTACK_IMAGE=localstack/localstack-pro:latest
# LOCALSTACK_AUTH_TOKEN=

