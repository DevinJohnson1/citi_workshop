# =============================================================================
# Example env file for docker-compose.yml — copy to `.env` before running
# `docker compose up`. Compose auto-loads `.env` from the project root.
#
#   cp .env.example .env
#
# `.env` itself is git-ignored (see .gitignore). Never commit real secrets.
# These defaults are workshop-safe (local-only, plaintext "postgres123") and
# match the fallbacks baked into bin/migrate.sh + infra/locals.tf, so you can
# run the workshop without editing this file at all.
# =============================================================================

# ---- Postgres (workshop-postgres container) ---------------------------------
# Used by docker-compose.yml to bootstrap the database on first start, and by
# bin/migrate.sh when connecting from the host. Only active when the "postgres"
# Compose profile is enabled (Community LocalStack or aws_postgres_enabled=false).
POSTGRES_USER=postgres
POSTGRES_PASS=postgres123
POSTGRES_NAME=postgres

# ---- LocalStack image -------------------------------------------------------
# Default: Community edition (no licence required, no Aurora RDS support).
# Uncomment and add your token to use LocalStack Pro (enables Aurora RDS).
# bin/start-dev.sh auto-detects the image and sets aws_postgres_enabled
# accordingly — no manual TF_VAR overrides required.
#
# Community (default — postgres container used for DB):
LOCALSTACK_IMAGE=localstack/localstack:latest
# LOCALSTACK_AUTH_TOKEN=
#
# Pro (Aurora RDS used instead of postgres container):
# LOCALSTACK_IMAGE=localstack/localstack-pro:latest
# LOCALSTACK_AUTH_TOKEN=ls-xxxxxxxxxxxxxxxxxxxx

# ---- Docker Compose profiles ------------------------------------------------
# Controls which optional services start when running `docker compose up -d`
# WITHOUT using bin/start-dev.sh (which auto-detects and sets this).
#
#   Community / no-RDS  →  COMPOSE_PROFILES=postgres  (starts the postgres fallback)
#   Pro / Aurora        →  COMPOSE_PROFILES=           (postgres not started)
#
# bin/start-dev.sh sets this automatically; set it here only when running
# docker compose directly.
COMPOSE_PROFILES=postgres

